#!/usr/bin/env php
<?php
/**
 * BATTLE ARENA - TERMINAL GAME v2
 * Um jogo de batalha táticas em tempo real no terminal
 * Com ASCII arts integradas, efeitos especiais e formas transformadas
 */

require_once __DIR__ . '/config/Database.php';
require_once __DIR__ . '/interfaces/ActionInterface.php';
require_once __DIR__ . '/classes/Character.php';
require_once __DIR__ . '/classes/ASCIIArts.php';
require_once __DIR__ . '/classes/Sukuna.php';
require_once __DIR__ . '/classes/Goku.php';
require_once __DIR__ . '/classes/Naruto.php';
require_once __DIR__ . '/classes/Ichigo.php';
require_once __DIR__ . '/classes/Subaru.php';
require_once __DIR__ . '/managers/BattleManager.php';

// ============================================
// CORES ANSI
// ============================================

const RESET = "\033[0m";
const BOLD = "\033[1m";
const RED = "\033[91m";
const GREEN = "\033[92m";
const YELLOW = "\033[93m";
const BLUE = "\033[94m";
const MAGENTA = "\033[95m";
const CYAN = "\033[96m";
const WHITE = "\033[97m";
const BG_BLACK = "\033[40m";
const BG_RED = "\033[41m";
const BG_GREEN = "\033[42m";
const BG_BLUE = "\033[44m";

// ============================================
// JOGO PRINCIPAL
// ============================================

class TerminalBattle {
    private $battleManager;
    private $turn = 1;
    private $playerNames = ['Player 1', 'Player 2'];
    private $selectedCharacters = [];
    private $playerForms = ['Normal', 'Normal'];
    private $effects = [];
    private $returnByDeathUsage = [0, 0];
    
    public function __construct() {
        $this->clearScreen();
        $this->showWelcome();
        $this->selectPlayers();
        $this->startBattle();
    }
    
    private function clearScreen() {
        system('clear');
    }
    
    private function showWelcome() {
        echo CYAN . BOLD . "
╔════════════════════════════════════════════════════════════════╗
║                   BATTLE ARENA TERMINAL v2.0                   ║
║              Anime Fighters - Strategy Battle Game              ║
║                    Com Efeitos Especiais!                       ║
║  Escolha seus personagens e lutte em epicas batalhas!          ║
╚════════════════════════════════════════════════════════════════╝
        " . RESET . "\n";
        $this->pressEnter();
    }
    
    private function selectPlayers() {
        $this->clearScreen();
        echo YELLOW . BOLD . "SELECAO DE PERSONAGENS\n" . RESET;
        echo str_repeat("=", 60) . "\n\n";
        
        $characters = [
            'Sukuna' => [
                'hp' => 1800, 'atk' => 95, 'def' => 70, 'spd' => 90,
                'desc' => 'Rei das Maldicoes - Bleed & Dano Continuo',
                'forms' => ['Normal', 'HEIAN ERA']
            ],
            'Goku' => [
                'hp' => 1600, 'atk' => 120, 'def' => 60, 'spd' => 110,
                'desc' => 'Super Saiyajin - Velocista extremo',
                'forms' => ['Normal', 'Super Saiyajin', 'Ultra Instinto']
            ],
            'Naruto' => [
                'hp' => 1900, 'atk' => 85, 'def' => 80, 'spd' => 85,
                'desc' => 'Ninja Shinobi - Balanceado e resistente',
                'forms' => ['Normal', 'Modo Kurama', 'Sabio dos Seis Caminhos']
            ],
            'Ichigo' => [
                'hp' => 1700, 'atk' => 100, 'def' => 75, 'spd' => 95,
                'desc' => 'Soul Reaper - Espadachim equilibrado',
                'forms' => ['Normal', 'Bankai', 'Hollow Ichigo']
            ],
            'Subaru' => [
                'hp' => 1400, 'atk' => 70, 'def' => 85, 'spd' => 100,
                'desc' => 'Return by Death - Controlador de tempo',
                'forms' => ['Normal', 'Resolvido', 'Loop Master']
            ]
        ];
        
        for ($p = 1; $p <= 2; $p++) {
            echo ($p === 1 ? GREEN : BLUE) . BOLD . "JOGADOR $p\n" . RESET;
            echo "Digite seu nome (padrao: Player $p): ";
            $name = trim(fgets(STDIN));
            $this->playerNames[$p - 1] = empty($name) ? "Player $p" : $name;
            
            echo "\nEscolha seu personagem:\n";
            $idx = 1;
            foreach ($characters as $char => $data) {
                echo "  [$idx] $char - " . $data['desc'] . "\n";
                echo "       HP: " . $data['hp'] . " ATK: " . $data['atk'] . 
                     " DEF: " . $data['def'] . " SPD: " . $data['spd'] . "\n\n";
                $idx++;
            }
            
            $idx--;
            while (true) {
                echo "Escolha [1-$idx]: ";
                $choice = trim(fgets(STDIN));
                if (is_numeric($choice) && $choice >= 1 && $choice <= $idx) {
                    $names = array_keys($characters);
                    $this->selectedCharacters[$p - 1] = $names[$choice - 1];
                    break;
                }
                echo RED . "OPCAO INVALIDA\n" . RESET;
            }
            echo "\n";
        }
        
        $this->clearScreen();
    }
    
    private function startBattle() {
        echo MAGENTA . BOLD . "
╔════════════════════════════════════════════════════════════════╗
║                  INICIANDO BATALHA                             ║
╚════════════════════════════════════════════════════════════════╝
        " . RESET . "\n";
        sleep(1);
        
        $this->battleManager = new BattleManager(
            $this->playerNames[0],
            $this->playerNames[1],
            $this->selectedCharacters[0],
            $this->selectedCharacters[1]
        );
        
        $this->runBattleLoop();
    }
    
    private function runBattleLoop() {
        while (true) {
            $this->clearScreen();
            $this->displayBattle();
            
            $state = $this->battleManager->getState();
            if ($state['player1']['character']->getCurrentHp() <= 0 || 
                $state['player2']['character']->getCurrentHp() <= 0) {
                $this->showBattleEnd();
                break;
            }
            
            $this->applyOngoingEffects();
            
            $this->executeTurn(1);
            usleep(500000);
            
            $this->executeTurn(2);
            usleep(500000);
            
            $this->turn++;
        }
    }
    
    private function displayBattle() {
        $state = $this->battleManager->getState();
        
        echo CYAN . BOLD . "TURNO " . $this->turn . "\n" . RESET;
        echo str_repeat("=", 60) . "\n\n";
        
        for ($p = 1; $p <= 2; $p++) {
            $pData = ($p === 1) ? $state['player1'] : $state['player2'];
            $char = $pData['character'];
            $color = ($p === 1) ? GREEN : BLUE;
            
            $hpPercent = ($char->getCurrentHp() / $char->getMaxHp()) * 100;
            $energyPercent = ($char->getCurrentEnergy() / $char->getMaxEnergy()) * 100;
            
            echo $color . BOLD . $this->playerNames[$p - 1] . RESET . "\n";
            echo "Personagem: " . $char->getType() . " (" . $this->playerForms[$p - 1] . ")\n\n";
            
            echo "HP:     " . $this->drawBar($hpPercent, 40);
            echo sprintf(" %d/%d\n", $char->getCurrentHp(), $char->getMaxHp());
            
            echo "Energia: " . $this->drawBar($energyPercent, 40, CYAN);
            echo sprintf(" %d/%d\n", $char->getCurrentEnergy(), $char->getMaxEnergy());
            
            if (!empty($this->effects[$p])) {
                echo "Efeitos: " . MAGENTA . implode(", ", $this->effects[$p]) . RESET . "\n";
            }
            
            echo "\n";
        }
        
        echo str_repeat("=", 60) . "\n";
        echo YELLOW . "HISTORICO\n" . RESET;
        
        $logs = array_slice($state['log'], -5);
        foreach ($logs as $log) {
            echo "  $log\n";
        }
        
        echo str_repeat("=", 60) . "\n\n";
    }
    
    private function drawBar($percent, $width, $color = GREEN) {
        $filled = intval(($percent / 100) * $width);
        $empty = $width - $filled;
        $bar = str_repeat("X", $filled) . str_repeat(".", $empty);
        return $color . $bar . RESET . " " . sprintf("%.0f%%", $percent);
    }
    
    private function executeTurn($player) {
        echo "\n" . ($player === 1 ? GREEN : BLUE) . BOLD . 
             "TURNO DO " . $this->playerNames[$player - 1] . "\n" . RESET;
        
        $state = $this->battleManager->getState();
        $char = ($player === 1) ? $state['player1']['character'] : $state['player2']['character'];
        
        $this->showActionMenu($player, $char);
        $this->pressEnterQuiet();
    }
    
    private function showActionMenu($player, $character) {
        while (true) {
            echo "\nESCOLHA UMA ACAO:\n";
            echo "  [1] ATACAR\n";
            echo "  [2] DEFENDER\n";
            echo "  [3] HABILIDADES ESPECIAIS\n";
            echo "  [4] MUDAR FORMA\n";
            echo "  [5] VER STATUS\n";
            echo "\nOpcao: ";
            
            $choice = trim(fgets(STDIN));
            
            switch ($choice) {
                case '1':
                    $this->executeAction($player, 'attack');
                    return;
                case '2':
                    $this->executeAction($player, 'defend');
                    return;
                case '3':
                    $this->showSpecialMoves($player, $character);
                    return;
                case '4':
                    $this->showFormSelection($player);
                    return;
                case '5':
                    $this->showDetailedStatus($player, $character);
                    break;
                default:
                    echo RED . "OPCAO INVALIDA\n" . RESET;
            }
        }
    }
    
    private function showSpecialMoves($player, $character) {
        $this->clearScreen();
        
        $moves = $this->getMovesForCharacter($character->getType());
        
        echo MAGENTA . BOLD . "HABILIDADES ESPECIAIS - " . $character->getType() . "\n" . RESET;
        echo str_repeat("=", 60) . "\n\n";
        
        $idx = 1;
        foreach ($moves as $key => $move) {
            $canUse = $character->getCurrentEnergy() >= $move['cost'] ? GREEN : RED;
            echo sprintf("  [%d] %s (Custo: %s%d%s Energia)\n",
                $idx, $move['name'], $canUse, $move['cost'], RESET);
            echo "      " . $move['desc'] . "\n\n";
            $idx++;
        }
        
        echo "  [0] VOLTAR\n\n";
        echo "Escolha: ";
        
        $choice = trim(fgets(STDIN));
        
        if ($choice === '0') {
            $this->showActionMenu($player, $character);
            return;
        }
        
        if (is_numeric($choice) && $choice >= 1 && $choice <= count($moves)) {
            $moveKeys = array_keys($moves);
            $selectedMove = $moveKeys[$choice - 1];
            
            // Mostra ASCII art
            $this->displayMoveASCII($selectedMove);
            
            $this->executeAction($player, $selectedMove);
        } else {
            echo RED . "OPCAO INVALIDA\n" . RESET;
            $this->pressEnter();
            $this->showSpecialMoves($player, $character);
        }
    }
    
    private function showFormSelection($player) {
        $state = $this->battleManager->getState();
        $character = ($player === 1) ? $state['player1']['character'] : $state['player2']['character'];
        
        $forms = $character->getForms();
        
        echo "\nFORMAS DISPONIVEIS:\n";
        foreach ($forms as $idx => $form) {
            $current = ($form === $character->getCurrentForm()) ? " [ATUAL]" : "";
            echo "  [" . ($idx + 1) . "] $form$current\n";
        }
        echo "\nEscolha: ";
        
        $choice = trim(fgets(STDIN));
        
        if (is_numeric($choice) && $choice >= 1 && $choice <= count($forms)) {
            $formName = $forms[$choice - 1];
            if ($character->applyForm($formName)) {
                $this->playerForms[$player - 1] = $formName;
                $this->executeAction($player, 'transform');
            }
        }
    }
    
    private function displayMoveASCII($move) {
        // Usa a classe ASCIIArts para exibir
        $ascii = ASCIIArts::getASCII($move);
        ASCIIArts::displayCutscene($ascii);
        $this->displayBattle();
    }
    
    private function executeAction($player, $action) {
        $state = $this->battleManager->getState();
        $char = ($player === 1) ? $state['player1']['character'] : $state['player2']['character'];
        
        // Lógica especial para Return by Death do Subaru
        if ($action === 'returnbydeath' && $char->getType() === 'Subaru') {
            if ($this->returnByDeathUsage[$player - 1] < 2) {
                // Mostra ASCII art de Return by Death
                $this->displayMoveASCII('returnbydeath');
                
                $this->returnByDeathUsage[$player - 1]++;
                
                // Restaura HP completo
                $char->setCurrentHp($char->getMaxHp());
                $char->setCurrentEnergy($char->getMaxEnergy());
                
                // Reseta efeitos negativos
                unset($this->effects[$player]);
                
                echo MAGENTA . BOLD . "⏰ RETURN BY DEATH ATIVADO!\n" . RESET;
                echo "   Batalha foi resetada para o início (uso " . $this->returnByDeathUsage[$player - 1] . "/2)\n";
                echo "   HP restaurado para " . $char->getCurrentHp() . "\n\n";
                
                $this->pressEnter();
                
                // Reset da batalha
                $this->turn = 1;
                $this->effects = [];
                $this->returnByDeathUsage = [0, 0];
                
                return;
            } else {
                echo RED . "RETURN BY DEATH JAE FOI USADO 2 VEZES!\n" . RESET;
                $this->pressEnter();
                return;
            }
        }
        
        $this->battleManager->setAction($player, $action);
        
        // Aplica efeitos especiais
        if ($action === 'cleave' && $char->getType() === 'Sukuna') {
            $this->addEffect(3 - $player, 'SANGRAMENTO');
        }
        
        if ($action === 'shrine' && $char->getType() === 'Sukuna') {
            $this->addEffect(3 - $player, 'EXPANSAO DE DOMINIO');
        }
    }
    
    private function applyOngoingEffects() {
        $state = $this->battleManager->getState();
        
        for ($p = 1; $p <= 2; $p++) {
            if (!empty($this->effects[$p])) {
                $enemy = ($p === 1) ? $state['player2']['character'] : $state['player1']['character'];
                
                if (in_array('SANGRAMENTO', $this->effects[$p])) {
                    $damage = $enemy->getMaxHp() * 0.05;
                    $enemy->takeDamage($damage);
                    $state['log'][] = RED . "SANGRAMENTO: " . $this->playerNames[2 - $p] . 
                                     " sofre " . intval($damage) . " dano" . RESET;
                }
                
                if (in_array('EXPANSAO DE DOMINIO', $this->effects[$p])) {
                    $damage = $enemy->getMaxHp() * 0.08;
                    $enemy->takeDamage($damage);
                    $state['log'][] = MAGENTA . "DOMINIO: " . $this->playerNames[2 - $p] . 
                                     " sofre " . intval($damage) . " dano" . RESET;
                }
            }
        }
    }
    
    private function addEffect($player, $effect) {
        if (!isset($this->effects[$player])) {
            $this->effects[$player] = [];
        }
        if (!in_array($effect, $this->effects[$player])) {
            $this->effects[$player][] = $effect;
        }
    }
    
    private function getFormsForCharacter($type) {
        $forms = [
            'Sukuna' => ['Normal', 'HEIAN ERA'],
            'Goku' => ['Normal', 'Super Saiyajin', 'Ultra Instinto'],
            'Naruto' => ['Normal', 'Modo Kurama', 'Sabio'],
            'Ichigo' => ['Normal', 'Bankai', 'Hollow'],
            'Subaru' => ['Normal', 'Resolvido', 'Loop Master']
        ];
        return $forms[$type] ?? ['Normal'];
    }
    
    private function getMovesForCharacter($type) {
        $moves = [
            'Sukuna' => [
                'cleave' => ['name' => 'CLEAVE', 'cost' => 30, 
                            'desc' => 'Ataque com sangramento continuo'],
                'dismantle' => ['name' => 'DISMANTLE', 'cost' => 40,
                               'desc' => 'Multiplos cortes destrutivos'],
                'shrine' => ['name' => 'MALEVOLENT SHRINE', 'cost' => 80,
                            'desc' => 'Dano continuo por 3 turnos']
            ],
            'Goku' => [
                'kamehameha' => ['name' => 'KAMEHAMEHA', 'cost' => 40,
                                'desc' => 'Onda de energia lendaria'],
                'genkidama' => ['name' => 'GENKIDAMA', 'cost' => 60,
                               'desc' => 'Bomba cosmica'],
                'teleport' => ['name' => 'ULTRA INSTINTO', 'cost' => 70,
                              'desc' => 'Esquiva com contraataque']
            ],
            'Naruto' => [
                'rasengan' => ['name' => 'RASENGAN', 'cost' => 35,
                              'desc' => 'Esfera giratoria de chi'],
                'rasenshuriken' => ['name' => 'RASENSHURIKEN', 'cost' => 55,
                                   'desc' => 'Shuriken de ar com multiplos golpes'],
                'kurama' => ['name' => 'MODO KURAMA', 'cost' => 75,
                            'desc' => 'Poder maximo da raposa']
            ],
            'Ichigo' => [
                'getsuga' => ['name' => 'GETSUGA TENSHO', 'cost' => 40,
                             'desc' => 'Ataque lunar classico'],
                'bankai' => ['name' => 'BANKAI', 'cost' => 60,
                            'desc' => 'Forma final da Zanpakuto'],
                'hollow' => ['name' => 'HOLLOW FORM', 'cost' => 50,
                            'desc' => 'Transformacao sinistra']
            ],
            'Subaru' => [
                'whitewhale' => ['name' => 'WHITE WHALE', 'cost' => 50,
                                'desc' => 'Poder do Leviata Branco'],
                'returnbydeath' => ['name' => 'RETURN BY DEATH', 'cost' => 90,
                                   'desc' => 'Volta no tempo e restaura HP'],
                'packed_lunch' => ['name' => 'PACKED LUNCH', 'cost' => 35,
                                  'desc' => 'Ataque com a mochila']
            ]
        ];
        return $moves[$type] ?? [];
    }
    
    private function showDetailedStatus($player, $character) {
        $this->clearScreen();
        
        echo ($player === 1 ? GREEN : BLUE) . BOLD . $this->playerNames[$player - 1] . RESET . "\n";
        echo str_repeat("=", 60) . "\n\n";
        
        echo sprintf("Personagem: %s (%s)\n", $character->getType(), $this->playerForms[$player - 1]);
        echo sprintf("HP:         %d/%d\n", $character->getCurrentHp(), $character->getMaxHp());
        echo sprintf("Energia:    %d/%d\n", $character->getCurrentEnergy(), $character->getMaxEnergy());
        echo sprintf("Ataque:     %d\n", $character->getAttack());
        echo sprintf("Defesa:     %d\n", $character->getDefense());
        echo sprintf("Velocidade: %d\n\n", $character->getSpeed());
        
        if (!empty($this->effects[$player])) {
            echo "Efeitos Ativos:\n";
            foreach ($this->effects[$player] as $effect) {
                echo "  - $effect\n";
            }
        }
        
        echo "\n";
        $this->pressEnter();
    }
    
    private function showBattleEnd() {
        $state = $this->battleManager->getState();
        
        $winner = $state['player1']['character']->getCurrentHp() > 0 ? 1 : 2;
        
        $this->clearScreen();
        
        echo ($winner === 1 ? GREEN : BLUE) . BOLD . "
╔════════════════════════════════════════════════════════════════╗
║                                                                ║
║                  BATALHA FINALIZADA!                          ║
║                                                                ║
║  VENCEDOR: " . str_pad(strtoupper($this->playerNames[$winner - 1]), 47) . "║
║                                                                ║
╚════════════════════════════════════════════════════════════════╝
        " . RESET . "\n\n";
        
        echo YELLOW . BOLD . "ESTATISTICAS FINAIS\n" . RESET;
        echo str_repeat("=", 60) . "\n\n";
        
        for ($p = 1; $p <= 2; $p++) {
            $pData = ($p === 1) ? $state['player1'] : $state['player2'];
            $char = $pData['character'];
            $color = ($p === 1) ? GREEN : BLUE;
            
            echo $color . BOLD . $this->playerNames[$p - 1] . " (" . 
                 $char->getType() . " - " . $this->playerForms[$p - 1] . ")" . RESET . "\n";
            echo sprintf("  HP Final:  %d/%d\n", $char->getCurrentHp(), $char->getMaxHp());
            echo sprintf("  Energia:   %d/%d\n", $char->getCurrentEnergy(), $char->getMaxEnergy());
            echo sprintf("  Turnos:    %d\n\n", $this->turn);
        }
        
        echo str_repeat("=", 60) . "\n";
        echo "Pressione ENTER para sair...";
        $this->pressEnter();
    }
    
    private function pressEnter() {
        fgets(STDIN);
    }
    
    private function pressEnterQuiet() {
        // Para testes, remova o comentario para pular automatico
        // fgets(STDIN);
    }
}

// ============================================
// INICIAR JOGO
// ============================================

try {
    new TerminalBattle();
} catch (Exception $e) {
    echo RED . "ERRO: " . $e->getMessage() . RESET . "\n";
    exit(1);
}
